# ── Infrastructure ────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-minimum-32-characters-long
DB_USER=sstb
DB_PASSWORD=change-me-strong-password
DB_NAME=sstb

# ── MikroTik Router ───────────────────────────────────────────────────────────
# TIDAK WAJIB — device MikroTik ditambah dan dikelola lewat Settings tab di dashboard.
# Opsional: isi sebagai fallback jika DB belum memiliki default device.
# MIKROTIK_API_URL=https://192.168.X.X/
# MIKROTIK_API_USER=sstb-api
# MIKROTIK_API_PASSWORD=your-mikrotik-api-password

# ── Threat Intelligence APIs ──────────────────────────────────────────────────
# NVD: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your-nvd-api-key

# VirusTotal: https://www.virustotal.com/gui/user/apikey
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# AlienVault OTX: https://otx.alienvault.com/api
ALIENVAULT_API_KEY=your-alienvault-api-key

# ThreatFox: https://threatfox.abuse.ch/api/
THREAT_FOX_API_KEY=your-threatfox-api-key

# URLScan: https://urlscan.io/user/profile/
URLSCAN_API_KEY=your-urlscan-api-key
